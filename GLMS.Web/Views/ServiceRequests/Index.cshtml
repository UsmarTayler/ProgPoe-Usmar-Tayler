@model IEnumerable<GLMS.Shared.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-tasks me-2"></i>Service Requests</h2>
    <a asp-action="Create" class="btn btn-info text-white"><i class="fas fa-plus me-2"></i>New Request</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Contract</th>
                    <th>Client</th>
                    <th>Description</th>
                    <th>Cost (USD)</th>
                    <th>Cost (ZAR)</th>
                    <th>Rate Used</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var sr in Model)
                {
                    <tr>
                        <td>@sr.Id</td>
                        <td>#@sr.ContractId</td>
                        <td>@sr.Contract?.Client?.Name</td>
                        <td>@sr.Description</td>
                        <td class="text-success fw-bold">$@(sr.CostUSD.ToString("F2"))</td>
                        <td class="text-primary fw-bold">R@(sr.CostZAR.ToString("F2"))</td>
                        <td><small class="text-muted">@sr.ExchangeRateUsed.ToString("F4")</small></td>
                        <td>
                            @{
                                var color = sr.Status switch {
                                    ServiceRequestStatus.Pending    => "warning",
                                    ServiceRequestStatus.InProgress => "info",
                                    ServiceRequestStatus.Completed  => "success",
                                    ServiceRequestStatus.Cancelled  => "danger",
                                    _                               => "secondary"
                                };
                            }
                            <span class="badge bg-@color text-dark">@sr.Status</span>
                        </td>
                        <td><small>@sr.CreatedAt.ToString("dd MMM yyyy")</small></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@sr.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@sr.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@sr.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="10" class="text-center text-muted py-4">No service requests. <a asp-action="Create">Create one.</a></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
