@model GLMS.Shared.Models.ServiceRequest
@{
    ViewData["Title"] = "Delete Service Request";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="fas fa-trash me-2"></i>Delete Service Request #@Model.Id</h5>
            </div>
            <div class="card-body">
                <p>Are you sure you want to delete this service request?</p>
                <p><strong>Description:</strong> @Model.Description</p>
                <p><strong>Cost:</strong> $@(Model.CostUSD) USD = R@(Model.CostZAR) ZAR</p>
                <p><strong>Status:</strong> @Model.Status</p>
                <form asp-action="Delete" method="post">
                    <input type="hidden" asp-for="Id" />
                    <button type="submit" class="btn btn-danger me-2">Yes, Delete</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
