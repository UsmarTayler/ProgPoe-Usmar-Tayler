@model GLMS.Shared.Models.ServiceRequest
@{
    ViewData["Title"] = $"Edit Service Request #{Model.Id}";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header bg-warning">
                <h5 class="mb-0"><i class="fas fa-edit me-2"></i>Edit Service Request #@Model.Id</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ContractId" />
                    <input type="hidden" asp-for="CostUSD" />
                    <input type="hidden" asp-for="CostZAR" />
                    <input type="hidden" asp-for="ExchangeRateUsed" />
                    <input type="hidden" asp-for="CreatedAt" />

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Status</label>
                        <select asp-for="Status" class="form-select" asp-items="ViewBag.StatusOptions"></select>
                    </div>

                    <div class="alert alert-info small">
                        <strong>Note:</strong> Cost and exchange rate cannot be changed after creation.
                        Original: $@(Model.CostUSD) USD = R@(Model.CostZAR) ZAR (rate: @Model.ExchangeRateUsed)
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-warning"><i class="fas fa-save me-2"></i>Update</button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
