@model IEnumerable<GLMS.Shared.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-users me-2"></i>Clients</h2>
    <a asp-action="Create" class="btn btn-primary"><i class="fas fa-plus me-2"></i>Add Client</a>
</div>

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Phone</th>
                    <th>Region</th>
                    <th>Contracts</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var client in Model)
                {
                    <tr>
                        <td><strong>@client.Name</strong></td>
                        <td>@client.Email</td>
                        <td>@client.Phone</td>
                        <td><span class="badge bg-secondary">@client.Region</span></td>
                        <td>@client.Contracts.Count</td>
                        <td>
                            <a asp-action="Details" asp-route-id="@client.Id" class="btn btn-sm btn-outline-info">Details</a>
                            <a asp-action="Edit" asp-route-id="@client.Id" class="btn btn-sm btn-outline-warning">Edit</a>
                            <a asp-action="Delete" asp-route-id="@client.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="6" class="text-center text-muted py-4">No clients found. <a asp-action="Create">Add one now.</a></td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
