@{
    ViewData["Title"] = "Login";
    Layout = null; // Full-page login — no navbar/sidebar
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>GLMS — Login</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body { background: #1a1a2e; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .login-card { background: white; border-radius: 12px; padding: 2.5rem; width: 100%; max-width: 420px; box-shadow: 0 20px 60px rgba(0,0,0,0.4); }
        .logo { font-size: 2rem; font-weight: 700; color: #0d6efd; text-align: center; margin-bottom: 0.25rem; }
        .subtitle { text-align: center; color: #6c757d; margin-bottom: 2rem; font-size: 0.9rem; }
        .hint { background: #e8f4fd; border-left: 4px solid #0d6efd; padding: 0.75rem 1rem; border-radius: 4px; font-size: 0.85rem; color: #0d47a1; margin-bottom: 1.5rem; }
    </style>
</head>
<body>
    <div class="login-card">
        <div class="logo">🚚 GLMS</div>
        <div class="subtitle">Global Logistics Management System<br/><small>Part 3 — SOA Architecture</small></div>

        <div class="hint">
            <strong>Demo Credentials:</strong><br/>
            Username: <code>admin</code> &nbsp; Password: <code>Admin123!</code>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }

        <form method="post" asp-action="Login" asp-controller="Account">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

            <div class="mb-3">
                <label for="username" class="form-label fw-semibold">Username</label>
                <input type="text" id="username" name="username" class="form-control"
                       placeholder="admin" autocomplete="username" />
            </div>

            <div class="mb-4">
                <label for="password" class="form-label fw-semibold">Password</label>
                <input type="password" id="password" name="password" class="form-control"
                       placeholder="Admin123!" autocomplete="current-password" />
            </div>

            <button type="submit" class="btn btn-primary w-100 py-2">
                Sign In
            </button>
        </form>

        <p class="text-center text-muted mt-3" style="font-size:0.75rem;">
            PROG7311 POE Part 3 — Tayler Usmar (ST10445063)
        </p>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
